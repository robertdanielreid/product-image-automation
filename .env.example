# REQUIRED: create at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Cheapest reliable vision model. Do not change unless this model is retired.
GEMINI_MODEL=gemini-2.5-flash-lite
VISION_APPROVAL_THRESHOLD=98

# Conservative defaults for a 2019 Intel Mac.
ACQUIRE_WORKERS=6
GEMINI_WORKERS=2
GEMINI_RPS=1
MAX_RETRY_PASSES=3

# 0 means process every unresolved row with browser fallback.
BROWSER_FALLBACK_LIMIT=0

# Optional. Existing DeepSeek-Claude Code configuration is normally reused.
DEEPSEEK_API_KEY=
